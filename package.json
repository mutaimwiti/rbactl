{
  "name": "rbactl",
  "version": "0.2.0",
  "description": "Easy and intuitive role-based access control library for Express apps.",
  "main": "index.js",
  "types": "lib/index.d.ts",
  "files": [
    "/lib",
    "/index.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "clean": "rimraf lib",
    "test": "jest --colors",
    "test:watch": "jest --colors --watch",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "yarn clean && yarn build && yarn lint && yarn test"
  },
  "pre-commit": [
    "clean",
    "build",
    "lint",
    "test"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mutaimwiti/rbactl.git"
  },
  "keywords": [
    "rbac",
    "rbactl",
    "node",
    "node-rbac",
    "nodejs",
    "nodejs-rbac",
    "express",
    "express-rbac",
    "authorize",
    "express-authorize",
    "authorization",
    "express-authorization"
  ],
  "author": "Mutai Mwiti <mutaimwiti40@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mutaimwiti/rbactl/issues"
  },
  "homepage": "https://github.com/mutaimwiti/rbactl#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/require-all": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "pre-commit": "^1.2.2",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "roots": [
      "test"
    ],
    "verbose": true,
    "coverageReporters": [
      "text",
      "lcov",
      "clover"
    ],
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "transform": {
      "^.+\\.[tj]s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  },
  "dependencies": {
    "logical-compiler": "^0.4.0",
    "require-all": "^3.0.0"
  }
}
