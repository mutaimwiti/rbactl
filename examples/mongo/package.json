{
  "name": "simple",
  "version": "0.0.1",
  "main": "server.js",
  "scripts": {
    "build:lib": "cd ../../ && yarn && yarn clean && yarn build",
    "pretest": "yarn build:lib",
    "prestart": "yarn build:lib",
    "test": "NODE_ENV=test jest --colors --runInBand --forceExit",
    "start": "nodemon server.js",
    "seed": "node seeder/seed.js",
    "seed:undo": "node seeder/undo.js"
  },
  "author": "Mutai Mwiti",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "verbose": true,
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>test/testUtils/config/setup.js"
    ],
    "globalSetup": "<rootDir>test/testUtils/config/globalSetup.js"
  }
}
